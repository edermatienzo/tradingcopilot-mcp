# Massive.com REST API key
# Get yours at https://massive.com
MASSIVE_API_KEY=your_massive_api_key_here

# OAuth 2.0 Client Credentials
# Run: npm run generate-secrets  to auto-fill these three values
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Secret used to sign and verify JWT access tokens (use a long random string)
JWT_SECRET=

# Access token lifetime in seconds (default: 3600 = 1 hour)
TOKEN_TTL_SECONDS=3600

# Port the MCP SSE server will listen on (default: 3000)
PORT=3000

# Externally reachable URL — required when using Claude.ai (cloud).
# Use ngrok or similar: ngrok http 3000  →  copy the https URL here.
# Leave unset for local-only use (Claude Desktop / Claude Code CLI).
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app
